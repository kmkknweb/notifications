{
  "version": 2,
  "builds": [
    { "src": "api/send-notification.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "firebase-messaging-sw.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/send-notification.js" },
    { "src": "/firebase-messaging-sw.js", "dest": "/firebase-messaging-sw.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
